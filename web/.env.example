# Copy this file to .env (which is gitignored) and fill in your key to
# enable optional LLM-backed scene enrichment (see GeminiNarratorAdapter.ts
# and canon/style-bible.md §6). Leave .env absent/empty and the game runs
# identically without it — this is a pure enhancement, never required.
#
# Get a key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Optional — defaults to gemini-flash-latest (an auto-updating alias) if unset.
# VITE_GEMINI_MODEL=gemini-flash-latest
