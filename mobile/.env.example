# Copy this file to .env (which is gitignored) and fill in your key to
# enable optional LLM-backed scene enrichment on mobile — same feature as
# /web's, see GeminiNarratorAdapter.ts and canon/style-bible.md §6. Leave
# .env absent/empty and the game runs identically without it.
#
# The EXPO_PUBLIC_ prefix is required — Expo's Metro config only inlines
# env vars with that prefix into the app bundle (anything else stays
# server/build-only and won't be visible at runtime).
#
# Get a key at https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional — defaults to gemini-flash-latest (an auto-updating alias) if unset.
# EXPO_PUBLIC_GEMINI_MODEL=gemini-flash-latest
